{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-vl:latest": {
          "name": "Qwen3 VL"
        }
      }
    }
  },
  "model": "github-copilot/claude-opus-4.6",
  "small_model": "github-copilot/claude-opus-4.6",
   "agent": {
    "explore": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "general": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "discovery-agent": {
      "model": "github-copilot/claude-opus-4.6",
      "permission": {
        "*": "allow",
        "edit": "deny",
        "write": "deny"
      }
    },
    "implementation-agent": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "librarian": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "oracle": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "Sisyphus-Junior": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "test-agent": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "verification-agent": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "all",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "permission": {
        "edit": "deny"
      }
    }
  },
  "permission": {
    "*": "allow"
  },
  "tools": {
    "write": true,
    "edit": true,
    "bash": true
  },
  "instructions": [
    "AGENTS.md"
  ],
  "snapshot": true,
  "autoupdate": true,
  "share": "manual",
  "mcp": {
    "code-rag": {
      "type": "local",
      "command": [
        "./.opencode/mcp-servers/code-rag/venv/bin/python3",
        "./.opencode/mcp-servers/code-rag/server.py"
      ],
      "enabled": true
    },
      "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    }
  }
  
}
