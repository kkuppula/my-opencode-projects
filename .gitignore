# Only include .opencode/ pipeline infrastructure
# Everything else is excluded

# Exclude all by default
*

# Include .opencode/ contents
!.opencode/
!.opencode/**

# Include repo root files
!.gitignore
!README.md
!LICENSE

# Exclude runtime/generated within .opencode
.opencode/sessions/
.opencode/cache/
.opencode/node_modules/
.opencode/package-lock.json
.opencode/mcp-servers/code-rag/venv/
.opencode/mcp-servers/code-rag/.chroma/
.opencode/mcp-servers/code-rag/indexer.log

# OS files
.DS_Store

# Credentials
*.env
.env.*
credentials.json
*token*
*secret*
